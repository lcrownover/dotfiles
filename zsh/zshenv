# Runs for ALL shells

case "$(uname -p)" in
    i386) export HOMEBREW_BINDIR="/usr/local/bin" ;;
    *)    export HOMEBREW_BINDIR="/opt/homebrew/bin" ;;
esac

case "$(uname -s)" in
    Darwin)
        _brew_env_cache="${XDG_CACHE_HOME:-$HOME/.cache}/brew_shellenv.zsh"
        [[ ! -f "$_brew_env_cache" ]] && $HOMEBREW_BINDIR/brew shellenv >| "$_brew_env_cache"
        source "$_brew_env_cache"
        ;;
esac

export EDITOR="nvim"
