case "$(uname -a)" in
    Darwin*)
        export DOT_OS="mac"
        ;;
    *WSL*)
        export DOT_OS="wsl"
        ;;
    *)
        export DOT_OS="linux"
        ;;
esac

if [ -z $TMUX ]; then
    if  [[ "$DOT_OS" = "wsl" ]]; then
        tmux new-session -A -s main -n ''
    elif [[ "$TERM" = "xterm-kitty" ]]; then # attach to main if terminal is kitty
        tmux new-session -A -s main -n ''
        # :
    elif [[ "$TERM_PROGRAM" = "iTerm.app" ]]; then
        :
    elif [[ "$TERM_PROGRAM" = "vscode" ]]; then
        :
    elif [[ "$TERM_PROGRAM" = "WezTerm" ]]; then
        :
    elif [[ "$TERM_PROGRAM" = "ghostty" ]]; then
        tmux new-session -A -s main -n ''
        # :
    elif [[ "$TERM" = "xterm-256color" ]]; then # attach to main if terminal is alacritty/wezterm (this conflicts with vs code)
        # tmux new-session -A -s main -n ''
        :
    else
        :
    fi
fi

ulimit -n 4096

# use emacs style, not vim
bindkey -e

# zinit plugins and turbo loading
ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"
[ ! -d $ZINIT_HOME ] && mkdir -p "$(dirname $ZINIT_HOME)"
[ ! -d $ZINIT_HOME/.git ] && git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
source "${ZINIT_HOME}/zinit.zsh"
zinit ice wait lucid
zinit light zsh-users/zsh-autosuggestions
zinit ice wait lucid atinit"ZINIT[COMPINIT_OPTS]=-C; zicompinit; zicdreplay"
zinit light zdharma-continuum/fast-syntax-highlighting

eval "$(starship init zsh)"

